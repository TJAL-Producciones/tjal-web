---
// src/pages/index.astro — Home (ES)
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/translations';

const t = useTranslations('es');
const features = t('features.items') as string[];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Inicio"
  description="Cuoteando — Registrá y seguí tus pagos en cuotas sin complicaciones. App para Android."
  lang="es"
  canonicalPath="/"
>
  <!-- ░░ BOOT HERO ░░ -->
  <section class="hero-section" aria-label="Presentación">
    <div class="boot-sequence" aria-hidden="true">
      <p class="boot-line muted">TJAL PRODUCCIONES</p>
      <p class="boot-line muted">Copyright 2025 TJAL Producciones. All rights reserved.</p>
      <p class="boot-line muted">──────────────────────────────────────</p>
      <p class="boot-line">Detectando dispositivo... <span class="ok">[OK]</span></p>
      <p class="boot-line">Cargando módulos de cuotas... <span class="ok">[OK]</span></p>
      <p class="boot-line">Sistema listo.</p>
      <p class="boot-line muted">──────────────────────────────────────</p>
    </div>

    <div class="hero-title-block">
      <p class="section-label">APP ANDROID</p>
      <h1 class="hero-title">
        CUOTEANDO<span class="blink" aria-hidden="true"></span>
      </h1>
      <p class="hero-sub">
        Controlá tus cuotas.<br />Sin complicaciones.
      </p>
      <div class="hero-meta">
        <span class="version-tag">v1.x</span>
        <span class="version-tag">Android</span>
        <span class="version-tag">Gratis</span>
      </div>
    </div>

    <div class="hero-cta">
      <a href="https://play.google.com/store"
         target="_blank"
         rel="noopener noreferrer"
         class="btn-retro"
         id="hero-playstore-btn"
         aria-label="Descargar Cuoteando en Google Play Store">
        [ Descargar en Play Store ]
      </a>
    </div>
  </section>

  <hr class="ascii-divider" />

  <!-- ░░ ABOUT ░░ -->
  <section class="content-section" aria-labelledby="about-heading">
    <div class="terminal-box" data-title="ACERCA DE">
      <h2 id="about-heading" class="section-heading">
        <span class="prompt-char">C:\&gt;</span> ABOUT.EXE
      </h2>
      <p class="body-text">
        Cuoteando es una app para Android diseñada para registrar y hacer
        seguimiento de tus pagos en cuotas. Sin nube, sin suscripciones,
        sin datos enviados a ningún servidor. <strong>Tu información queda
        en tu teléfono.</strong>
      </p>
    </div>
  </section>

  <!-- ░░ FEATURES ░░ -->
  <section class="content-section" aria-labelledby="features-heading">
    <div class="terminal-box" data-title="CARACTERÍSTICAS">
      <h2 id="features-heading" class="section-heading">
        <span class="prompt-char">C:\&gt;</span> FEATURES.TXT
      </h2>
      <ul class="retro-list" role="list">
        {features.map((feat, i) => (
          <li>
            <span class="marker" aria-hidden="true">[{String(i + 1).padStart(2, '0')}]</span>
            <span>{feat}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <hr class="ascii-divider" />

  <!-- ░░ CTA DOWNLOAD ░░ -->
  <section class="cta-section" aria-labelledby="cta-heading">
    <p class="section-label">[ DESCARGA ]</p>
    <h2 id="cta-heading" class="cta-title">Disponible en Google Play</h2>
    <p class="body-text muted-text">
      Descargala gratuitamente desde Play Store.
    </p>
    <div class="cta-buttons">
      <a href="https://play.google.com/store"
         target="_blank"
         rel="noopener noreferrer"
         class="btn-retro"
         id="cta-playstore-btn">
        [ Descargar en Play Store ]
      </a>
      <a href={`${base}/privacidad/`} class="link-secondary" id="cta-privacy-link">
        Ver política de privacidad
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero-section {
    padding: 2rem 0 1.5rem;
  }

  .boot-sequence {
    margin-bottom: 2rem;
  }

  .boot-line {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-body);
    line-height: 1.6;
    opacity: 0;
    animation: fadeIn 0.3s ease forwards;
  }

  .boot-line:nth-child(1) { animation-delay: 0.0s; }
  .boot-line:nth-child(2) { animation-delay: 0.2s; }
  .boot-line:nth-child(3) { animation-delay: 0.4s; }
  .boot-line:nth-child(4) { animation-delay: 0.6s; }
  .boot-line:nth-child(5) { animation-delay: 0.9s; }
  .boot-line:nth-child(6) { animation-delay: 1.2s; }
  .boot-line:nth-child(7) { animation-delay: 1.4s; }

  .boot-line.muted { color: var(--text-muted); }

  .ok {
    color: var(--color-success);
    font-weight: 700;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateX(-4px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  .hero-title-block {
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeIn 0.5s ease 1.6s forwards;
  }

  .hero-title {
    font-family: var(--font-mono);
    font-size: clamp(2rem, 8vw, 3.5rem);
    color: var(--primary);
    letter-spacing: 0.12em;
    line-height: 1.1;
    margin: 0.25rem 0 0.75rem;
    text-shadow: 2px 2px 0 var(--color-brand-100);
  }

  .hero-sub {
    font-family: var(--font-body);
    font-size: clamp(1rem, 3vw, 1.25rem);
    color: var(--text-heading);
    line-height: 1.5;
    margin-bottom: 1rem;
  }

  .hero-meta {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 0.75rem;
  }

  .hero-cta {
    opacity: 0;
    animation: fadeIn 0.5s ease 2s forwards;
    margin-bottom: 1rem;
  }

  /* ── Content sections ── */
  .content-section {
    margin-bottom: 1.5rem;
  }

  .section-heading {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    font-weight: 400;
  }

  .prompt-char {
    color: var(--primary);
    font-weight: 700;
    margin-right: 6px;
  }

  .body-text {
    font-family: var(--font-body);
    font-size: 0.92rem;
    color: var(--text-body);
    line-height: 1.8;
  }

  /* ── CTA section ── */
  .cta-section {
    padding: 2rem 0;
    text-align: left;
  }

  .cta-title {
    font-size: clamp(1rem, 3vw, 1.3rem);
    color: var(--text-heading);
    margin: 0.5rem 0 0.75rem;
  }

  .muted-text {
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .cta-buttons {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .link-secondary {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    text-decoration: underline;
  }

  .link-secondary:hover {
    color: var(--primary);
  }
</style>
